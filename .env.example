# Option A: separate connection fields
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=kaaveri

# Option B: single connection string (preferred in production)
# MYSQL_URL=mysql://root:your_password@127.0.0.1:3306/kaaveri

# Optional SSL controls for hosted MySQL
# MYSQL_SSL=true
# MYSQL_SSL_INSECURE=false

# Required for admin uploads to /api/certifications
ADMIN_PANEL_KEY=change_this_secret

# Public website origin (used for metadata/canonical base)
NEXT_PUBLIC_SITE_URL=https://lyfee.in
